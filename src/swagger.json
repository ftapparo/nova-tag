{
  "openapi": "3.0.1",
  "info": {
    "title": "NOVA-TAG",
    "description": "API para controle de portão automatizado com leitura RFID das antenas TAG1 e TAG2",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Monitoramento",
      "description": "Verificacao de status e saude da API (health check)."
    },
    {
      "name": "Portões",
      "description": "Funcionalidades para controle de portão: abertura, fechamento e status."
    },
    {
      "name": "Lista",
      "description": "Operações de cache de TAGs (whitelist/blacklist)."
    }
  ],
  "paths": {
    "/v2/api/health": {
      "get": {
        "tags": [
          "Monitoramento"
        ],
        "summary": "Verificacao de status da API",
        "description": "Retorna o status de funcionamento da API e o ambiente atual. Quando a antena estiver sem resposta no healthcheck, retorna 503.",
        "responses": {
          "200": {
            "description": "API em funcionamento",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseHealth"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v2/api/healthcheck": {
      "get": {
        "tags": [
          "Monitoramento"
        ],
        "summary": "Verificacao de status da API",
        "description": "Retorna o status de funcionamento da API e o ambiente atual. Quando a antena estiver sem resposta no healthcheck, retorna 503.",
        "responses": {
          "200": {
            "description": "API em funcionamento",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseHealth"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v2/api/gate/restart": {
      "post": {
        "tags": [
          "Monitoramento"
        ],
        "summary": "Reinicia a conexão com a antena",
        "description": "Encerra as conexões e finaliza o processo para forçar reinício do container.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "examples": {
                "minimo": {
                  "summary": "Mínimo",
                  "value": {}
                }
              },
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conexão reiniciada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v2/api/gate/state": {
      "get": {
        "tags": [
          "Portões"
        ],
        "summary": "Obtém o estado atual do portão",
        "description": "Retorna o estado atual do portão (OPEN, CLOSED, UNKNOWN).",
        "responses": {
          "200": {
            "description": "Estado atual do portão",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/gate/open": {
      "post": {
        "tags": [
          "Portões"
        ],
        "summary": "Abre o portão",
        "description": "Envia comando para abrir o portão e permite informar um tempo de fechamento automático (autoCloseTime, em segundos). Se não for informado, o portão permanece aberto até comando de fechamento.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "examples": {
                "minimo": {
                  "summary": "Mínimo",
                  "value": {}
                },
                "completo": {
                  "summary": "Completo",
                  "value": {
                    "autoCloseTime": 10
                  }
                }
              },
              "schema": {
                "type": "object",
                "properties": {
                  "autoCloseTime": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Tempo em segundos para fechamento automático do portão"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comando de abertura enviado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v2/api/gate/close": {
      "post": {
        "tags": [
          "Portões"
        ],
        "summary": "Fecha o portão",
        "description": "Envia comando para fechar o portão imediatamente.",
        "responses": {
          "200": {
            "description": "Comando de fechamento enviado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v2/api/cache": {
      "get": {
        "tags": [
          "Lista"
        ],
        "summary": "Lista o cache de TAGs",
        "description": "Lista o cache de TAGs. Use type=positive|negative|all|whitelist|blacklist.",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "positive",
                "negative",
                "all",
                "whitelist",
                "blacklist"
              ]
            },
            "description": "Tipo de cache a listar."
          }
        ],
        "responses": {
          "200": {
            "description": "Cache listado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      },
      "delete": {
        "tags": [
          "Lista"
        ],
        "summary": "Limpa o cache de TAGs",
        "description": "Limpa o cache de TAGs. Use type=positive|negative|all|whitelist|blacklist.",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "positive",
                "negative",
                "all",
                "whitelist",
                "blacklist"
              ]
            },
            "description": "Tipo de cache a limpar."
          }
        ],
        "responses": {
          "200": {
            "description": "Cache limpo com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v2/api/cache/{tag}": {
      "delete": {
        "tags": [
          "Lista"
        ],
        "summary": "Remove uma TAG do cache",
        "description": "Remove uma TAG específica do cache (whitelist/blacklist).",
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "TAG a ser removida do cache."
          }
        ],
        "responses": {
          "200": {
            "description": "TAG removida do cache",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "message": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "errors": {
            "nullable": true,
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "example": null
          }
        }
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "data": {
            "nullable": true,
            "oneOf": [
              {
                "type": "object"
              },
              {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              {
                "type": "string"
              }
            ],
            "example": null
          },
          "message": {
            "type": "string",
            "example": "Erro ao processar requisicao."
          },
          "errors": {
            "nullable": true,
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "example": null
          }
        }
      },
      "HealthData": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "API Funcionando!"
          },
          "environment": {
            "type": "string",
            "example": "development"
          },
          "antennaStatus": {
            "type": "string",
            "example": "OK"
          },
          "antennaHealthcheckPending": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "ApiResponseHealth": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/HealthData"
          },
          "message": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "errors": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        }
      },
      "ApiHealthcheckPendingResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/HealthData"
          },
          "message": {
            "type": "string",
            "example": "Antena sem resposta no healthcheck."
          },
          "errors": {
            "nullable": true,
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              }
            ],
            "example": null
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Requisicao invalida",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Nao autorizado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Acesso negado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Recurso nao encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflito de estado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Entidade nao processavel",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Muitas requisicoes",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Erro interno do servidor",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "BadGateway": {
        "description": "Falha de gateway",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "Servico indisponivel",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      },
      "GatewayTimeout": {
        "description": "Tempo de resposta excedido",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      }
    }
  }
}
