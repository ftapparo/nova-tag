{
  "openapi": "3.0.1",
  "info": {
    "title": "NOVA-TAG",
    "description": "API para controle de portão automatizado com leitura RFID das antenas TAG1 e TAG2",
    "version": "2.0.0"
  },
  "tags": [
    {
      "name": "Monitoramento",
      "description": "Verificacao de status e saude da API (health check)."
    },
    {
      "name": "Portões",
      "description": "Funcionalidades para controle de portão: abertura, fechamento e status."
    },
    {
      "name": "Lista",
      "description": "Operações de cache de TAGs (whitelist/blacklist)."
    }
  ],
  "paths": {
    "/v2/api/health": {
      "get": {
        "tags": [
          "Monitoramento"
        ],
        "summary": "Verificacao de status da API",
        "description": "Retorna o status de funcionamento da API e o ambiente atual. Quando a antena estiver sem resposta no healthcheck, retorna 503.",
        "responses": {
          "200": {
            "description": "API em funcionamento",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "API Funcionando!"
                        },
                        "environment": {
                          "type": "string",
                          "example": "development"
                        },
                        "antennaStatus": {
                          "type": "string",
                          "example": "OK"
                        },
                        "antennaHealthcheckPending": {
                          "type": "boolean",
                          "example": false
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Antena sem resposta no healthcheck",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "API Funcionando!"
                        },
                        "environment": {
                          "type": "string",
                          "example": "development"
                        },
                        "antennaStatus": {
                          "type": "string",
                          "example": "HEALTHCHECK_PENDING"
                        },
                        "antennaHealthcheckPending": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "example": "Antena sem resposta no healthcheck."
                    },
                    "errors": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/healthcheck": {
      "get": {
        "tags": [
          "Monitoramento"
        ],
        "summary": "Verificacao de status da API",
        "description": "Retorna o status de funcionamento da API e o ambiente atual. Quando a antena estiver sem resposta no healthcheck, retorna 503.",
        "responses": {
          "200": {
            "description": "API em funcionamento",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "API Funcionando!"
                        },
                        "environment": {
                          "type": "string",
                          "example": "development"
                        },
                        "antennaStatus": {
                          "type": "string",
                          "example": "OK"
                        },
                        "antennaHealthcheckPending": {
                          "type": "boolean",
                          "example": false
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Antena sem resposta no healthcheck",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "API Funcionando!"
                        },
                        "environment": {
                          "type": "string",
                          "example": "development"
                        },
                        "antennaStatus": {
                          "type": "string",
                          "example": "HEALTHCHECK_PENDING"
                        },
                        "antennaHealthcheckPending": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "example": "Antena sem resposta no healthcheck."
                    },
                    "errors": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/gate/restart": {
      "post": {
        "tags": [
          "Monitoramento"
        ],
        "summary": "Reinicia a conexão com a antena",
        "description": "Reinicia a conexão socket com a antena RFID para recuperação de falhas. Use forceRestart para encerrar o container e forçar reinício pelo Docker.",
        "parameters": [
          {
            "name": "forceRestart",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Quando true, encerra o processo com exit(1) para forçar o reinício do container."
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "examples": {
                "minimo": {
                  "summary": "Mínimo",
                  "value": {}
                },
                "completo": {
                  "summary": "Completo",
                  "value": {
                    "forceRestart": true
                  }
                }
              },
              "schema": {
                "type": "object",
                "properties": {
                  "forceRestart": {
                    "type": "boolean",
                    "description": "Quando true, encerra o processo com exit(1) para forçar o reinício do container."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conexão reiniciada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Conexão com a antena reiniciada com sucesso."
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Falha ao reiniciar conexão com a antena",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "Falha ao reiniciar conexão com a antena."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/gate/state": {
      "get": {
        "tags": [
          "Portões"
        ],
        "summary": "Obtém o estado atual do portão",
        "description": "Retorna o estado atual do portão (OPEN, CLOSED, UNKNOWN).",
        "responses": {
          "200": {
            "description": "Estado atual do portão",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "state": {
                          "type": "string",
                          "enum": [
                            "OPEN",
                            "CLOSED",
                            "UNKNOWN"
                          ],
                          "example": "CLOSED"
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/gate/open": {
      "post": {
        "tags": [
          "Portões"
        ],
        "summary": "Abre o portão",
        "description": "Envia comando para abrir o portão e permite informar um tempo de fechamento automático (autoCloseTime, em segundos). Se não for informado, o portão permanece aberto até comando de fechamento.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "examples": {
                "minimo": {
                  "summary": "Mínimo",
                  "value": {}
                },
                "completo": {
                  "summary": "Completo",
                  "value": {
                    "autoCloseTime": 10
                  }
                }
              },
              "schema": {
                "type": "object",
                "properties": {
                  "autoCloseTime": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Tempo em segundos para fechamento automático do portão"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comando de abertura enviado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Comando de abertura enviado com sucesso."
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parâmetro inválido",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "Parâmetro autoCloseTime inválido. Informe um número inteiro."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Falha ao enviar comando",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "Falha ao enviar comando para abrir o portão."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/gate/close": {
      "post": {
        "tags": [
          "Portões"
        ],
        "summary": "Fecha o portão",
        "description": "Envia comando para fechar o portão imediatamente.",
