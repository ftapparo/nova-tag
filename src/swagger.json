                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Falha ao enviar comando",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "Falha ao enviar comando para fechar o portão."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/cache": {
      "get": {
        "tags": [
          "Lista"
        ],
        "summary": "Lista o cache de TAGs",
        "description": "Lista o cache de TAGs. Use type=positive|negative|all|whitelist|blacklist.",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "positive",
                "negative",
                "all",
                "whitelist",
                "blacklist"
              ]
            },
            "description": "Tipo de cache a listar."
          }
        ],
        "responses": {
          "200": {
            "description": "Cache listado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "positive"
                        },
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "tag": {
                                "type": "string",
                                "example": "005646665"
                              },
                              "validatedAt": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "isValid": {
                                "type": "boolean",
                                "example": true
                              },
                              "accessId": {
                                "type": "string",
                                "nullable": true,
                                "example": "123456"
                              },
                              "verifyData": {
                                "type": "object",
                                "nullable": true,
                                "example": {
                                  "PERMITIDO": "S",
                                  "NOME": "IGOR JOSE LIMA ROZANI",
                                  "MIDIA": "TAG",
                                  "DESCRICAO": "3 INQUILINO"
                                }
                              }
                            }
                          }
                        },
                        "stats": {
                          "type": "object",
                          "properties": {
                            "positiveSize": {
                              "type": "integer",
                              "example": 1
                            },
                            "negativeSize": {
                              "type": "integer",
                              "example": 1
                            },
                            "positiveTimeout": {
                              "type": "integer",
                              "example": 300000
                            },
                            "negativeTimeout": {
                              "type": "integer",
                              "example": 60000
                            }
                          },
                          "example": {
                            "positiveSize": 1,
                            "negativeSize": 1,
                            "positiveTimeout": 300000,
                            "negativeTimeout": 60000
                          }
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Tipo de cache inválido",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "Tipo de cache inválido. Use positive, negative, all, whitelist ou blacklist."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "TagValidator indisponível",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "TagValidator indisponível."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Lista"
        ],
        "summary": "Limpa o cache de TAGs",
        "description": "Limpa o cache de TAGs. Use type=positive|negative|all|whitelist|blacklist.",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "positive",
                "negative",
                "all",
                "whitelist",
                "blacklist"
              ]
            },
            "description": "Tipo de cache a limpar."
          }
        ],
        "responses": {
          "200": {
            "description": "Cache limpo com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Cache limpo com sucesso."
                        },
                        "type": {
                          "type": "string",
                          "example": "negative"
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Tipo de cache inválido",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "Tipo de cache inválido. Use positive, negative, all, whitelist ou blacklist."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "TagValidator indisponível",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "TagValidator indisponível."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/api/cache/{tag}": {
      "delete": {
        "tags": [
          "Lista"
        ],
        "summary": "Remove uma TAG do cache",
        "description": "Remove uma TAG específica do cache (whitelist/blacklist).",
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "TAG a ser removida do cache."
          }
        ],
        "responses": {
          "200": {
            "description": "TAG removida do cache",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "TAG removida do cache com sucesso."
                        },
                        "tag": {
                          "type": "string",
                          "example": "005017758"
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "TAG inválida",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "TAG inválida."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "TAG não encontrada no cache",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "TAG não encontrada no cache."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "TagValidator indisponível",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "message": {
                      "type": "string",
                      "example": "TagValidator indisponível."
                    },
                    "errors": {
                      "type": "string",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}